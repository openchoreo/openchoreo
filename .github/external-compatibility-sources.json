      "owner": "platform",
      "paths": [
        "config/crd/bases/*.yaml",
        "install/helm/**/*.yaml",
        "install/k3d/**/*.yaml",
        "samples/getting-started/workflow-templates/*.yaml"
      ],
      "affected_files": [
        "config/crd/bases/*.yaml",
        "install/helm/**/*.yaml",
        "install/k3d/**/*.yaml",
        "samples/getting-started/workflow-templates/*.yaml"
      ],
      "action": "Migrate removed Kubernetes API versions before installing or upgrading against the target Kubernetes version."
